# Copy to .env:   cp env.example .env

# Real swaps need a working RPC. Many providers return JSON-RPC "missing api key" / -32401 unless the key is in the URL.
# Example (Helius): SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
SOLANA_RPC_URL=
WALLET_PRIVATE_KEY=

# Public wallet shown on site + chat identity (must match pubkey of WALLET_PRIVATE_KEY)
# CHUD_WALLET_PUBLIC=ChUDLb94pRxseyHZYpiJwTcdWd2tTET62E4szEY8RbHk

# Starting SOL for /api/balance/chart and trades-only balance fallback. Change when you reset bankroll / new era.
# CHUD_CHART_START_SOL=1

# PumpPortal: optional. Keys from the Lightning “create wallet” flow are for POST /api/trade (Portal signs that wallet only).
# Chud uses POST https://pumpportal.fun/api/trade-local **without** ?api-key= by default (your WALLET_PRIVATE_KEY signs).
# Only append ?api-key= if Portal gave you a key explicitly for local tx with your pubkey:
# PUMPPORTAL_APPEND_KEY_TO_TRADE_LOCAL=1
# PUMPPORTAL_API_KEY=
# Legacy alias: PUMP_FUN_API_KEY=
# Optional: max wait for Portal to return a serialized tx (ms). Default 45000.
# CHUD_PUMPPORTAL_FETCH_MS=45000
# Max wait for RPC to report tx success/fail after send (ms). Default 45000 — lower = faster “dead” errors, higher = slow RPC tolerance.
# CHUD_TX_CONFIRM_MS=45000

# Buys: comma-separated PumpPortal `pool` values tried in order (see https://pumpportal.fun/local-trading-api/trading-api ).
# Code default is pump,auto only (fast); add raydium,pump-amm,… if you trade mostly graduated tokens.
# CHUD_BUY_POOL_FALLBACKS=pump,auto

# SOL kept back when OpenClaw/agent requests a buy (fees + headroom). With 0.08–0.21 SOL buys use ~0.06–0.10
# CHUD_WALLET_RESERVE_SOL=0.08

# Emergency: POST /api/agent/force-close clears stuck openTrade without PumpPortal (set a long random string).
# CHUD_FORCE_CLOSE_SECRET=
#
# Stop new buys without redeploy: GET /api/agent/trading-paused ; POST {"paused":true|false} with header
# X-Chud-Trading-Pause: <secret> (or body.secret). Secret = CHUD_TRADING_PAUSE_SECRET, or reuse CHUD_FORCE_CLOSE_SECRET.
# Or hard-pause until restart: CHUD_TRADING_PAUSED=1
# Optional: how long the bot sleeps between idle checks while paused (ms). Default 25000.
# CHUD_TRADING_PAUSE_POLL_MS=25000
# CHUD_TRADING_PAUSE_SECRET=
# Optional comma pools for sell retries (graduated pump → Raydium / PumpSwap AMM etc.). Defaults cover PumpPortal’s pool list.
# CHUD_SELL_POOL_FALLBACKS=auto,raydium,pump-amm,raydium-cpmm,launchlab,bonk,pump

# Claude for THIS app only: the website “chat with Chud” tab, and the built-in auto-trader (if you leave it on).
# Your OpenClaw / dashboard Claude is separate — do not put OpenClaw’s keys here; OpenClaw never reads this file.
ANTHROPIC_API_KEY=
# Cost control (this repo defaults to Haiku-class — keep ANTHROPIC_MODEL on Haiku, not Sonnet/Opus):
# ANTHROPIC_MODEL=claude-haiku-4-5
# Biggest spend driver = how often “sell or hold?” runs while you have a bag. Default 120000 = 2 min. Try 300000 (5m) or 600000 (10m):
# CHUD_HOLD_POLL_MS=300000
# Thought recap lines = 1 LLM call each tick. If set, use 30–60 minutes for heavy trading days, or unset to disable:
# CHUD_THOUGHT_POST_MINUTES=30
# Site "talk to chud" max output tokens per reply (default 560, range 64–4096). Your 400–600 range is fine; raise for longer rants.
# CHUD_CHAT_MAX_OUTPUT_TOKENS=640
# How often the backend may append a wallet balance sample to data/balance-snapshots.json (ms, 15000–3600000). Default 50000.
# CHUD_BALANCE_SNAPSHOT_MS=50000
# In OpenClaw’s own settings, pick the cheapest model that still feels OK for tool use (often Haiku / small) — that bill is separate from this .env.

# Local Ollama ($0, no cloud quota). Install from https://ollama.com then: ollama pull qwen2.5:7b  (or llama3.2, etc.)
# Leave cloud keys empty OR set CHUD_LLM_PROVIDER=ollama to force Ollama even if keys exist.
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# CHUD_LLM_PROVIDER=ollama

# Fully free option for this server (Google AI Studio key): picks, sell/hold, site chat, thought lines — no Anthropic/OpenAI needed.
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# Optional model id (default gemini-2.0-flash). Also accepts GOOGLE_AI_API_KEY / GOOGLE_GENERATIVE_AI_API_KEY.
# GEMINI_MODEL=gemini-2.0-flash

# --- 24/7 trading (recommended) vs OpenClaw-only ---
# Backend scans + buys + sells on its own (no chat session needed). OpenClaw can still call the agent API for overrides.
# CHUD_OPENCLAW_ONLY=0
# CHUD_AUTONOMOUS_LOOP=true
# Optional timer exit if no LLM keys: CHUD_FORCE_SELL_AFTER_MINUTES=20
#
# OpenClaw-only (chat must keep calling buy/sell; loop stays off):
# CHUD_OPENCLAW_ONLY=1
# CHUD_AUTONOMOUS_LOOP=false

# OPENAI_API_KEY=

# While holding a coin, the bot asks Claude “sell or hold?” on this interval (ms). Default 120000 = 2 min.
# CHUD_HOLD_POLL_MS=120000
# BIRDEYE_API_KEY=
# CHUD_OWN_TOKEN_MINT=   (bot never buys/sells this mint)
# --- Trade “tweets” without X API (default on) ---
# Every buy/sell writes tweet text to data/chud-outbox.json → GET /api/chud/outbox (site + OpenClaw can read/post manually).
# Set CHUD_TRADE_OUTBOX=0 to disable.
# CHUD_TRADE_OUTBOX=1
#
# X without paying for API: CHUD_X_POST_MODE=intent opens your **local** default browser (does nothing useful on Railway).
# For auto-posting from the server you need TWITTER_* keys, or run a small local script that polls /api/chud/outbox and opens intent URLs.
# Buy/sell X lines use OpenClaw buy `reason` / sell JSON `reason` when long enough (chud-prefixed).
# CHUD_X_SKIP_TRADE_TWEETS=1   # skip API/intent/playwright for buy/sell (outbox still written unless CHUD_TRADE_OUTBOX=0)
# TWITTER_DISABLED=1
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# CHUD_X_POST_MODE=intent

# Every N minutes: one lowercase “chud” recap — how the session / bag / last flips feel (for X + outbox).
# N is minutes (not seconds). Example: 4 = every 4 minutes (needs ANTHROPIC / GEMINI / OPENAI / OLLAMA on this server).
# Saved to data/chud-outbox.json and GET …/api/chud/outbox. If TWITTER_* or CHUD_X_POST_MODE is set, recap also goes to X.
# CHUD_THOUGHT_POST_MINUTES=4
