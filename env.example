# Copy to .env:   cp env.example .env

# Real swaps need a working RPC. Many providers return JSON-RPC "missing api key" / -32401 unless the key is in the URL.
# Example (Helius): SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
SOLANA_RPC_URL=
WALLET_PRIVATE_KEY=

# Public wallet shown on site + chat identity (must match pubkey of WALLET_PRIVATE_KEY)
# CHUD_WALLET_PUBLIC=ChUDLb94pRxseyHZYpiJwTcdWd2tTET62E4szEY8RbHk

# Starting SOL for /api/balance/chart and trades-only balance fallback. Change when you reset bankroll / new era.
# CHUD_CHART_START_SOL=1

# PumpPortal (recommended on Railway): https://www.pumpportal.fun/trading-api/setup/ — create API key, paste here.
# Chud calls POST https://pumpportal.fun/api/trade-local?api-key=THIS_KEY with your wallet in the form body (see clawdbot/src/trade.ts).
# PUMPPORTAL_API_KEY=
# Legacy alias also accepted:
# PUMP_FUN_API_KEY=
# Optional: max wait for Portal to return a serialized tx (ms). Default 90000.
# CHUD_PUMPPORTAL_FETCH_MS=90000

# Buys: comma-separated PumpPortal `pool` values tried in order (see https://pumpportal.fun/local-trading-api/trading-api ).
# Default starts with `pump` (bonding curve). If you see on-chain Custom 6021 = "notEnoughTokensToBuy" on every mint, you were
# likely on a bad `auto` route — keep defaults or set e.g. CHUD_BUY_POOL_FALLBACKS=pump,pump-amm,raydium,auto
# CHUD_BUY_POOL_FALLBACKS=pump,pump-amm,raydium,auto,bonk,launchlab,raydium-cpmm

# SOL kept back when OpenClaw/agent requests a buy (fees + headroom). With 0.08–0.21 SOL buys use ~0.06–0.10
# CHUD_WALLET_RESERVE_SOL=0.08

# Emergency: POST /api/agent/force-close clears stuck openTrade without PumpPortal (set a long random string).
# CHUD_FORCE_CLOSE_SECRET=
# Optional comma pools for sell retries (graduated pump → Raydium / PumpSwap AMM etc.). Defaults cover PumpPortal’s pool list.
# CHUD_SELL_POOL_FALLBACKS=auto,raydium,pump-amm,raydium-cpmm,launchlab,bonk,pump

# Claude for THIS app only: the website “chat with Chud” tab, and the built-in auto-trader (if you leave it on).
# Your OpenClaw / dashboard Claude is separate — do not put OpenClaw’s keys here; OpenClaw never reads this file.
ANTHROPIC_API_KEY=
# Cost control (this repo defaults to Haiku-class — keep ANTHROPIC_MODEL on Haiku, not Sonnet/Opus):
# ANTHROPIC_MODEL=claude-haiku-4-5
# Biggest spend driver = how often “sell or hold?” runs while you have a bag. Default 120000 = 2 min. Try 300000 (5m) or 600000 (10m):
# CHUD_HOLD_POLL_MS=300000
# Thought recap lines = 1 LLM call each tick. If set, use 30–60 minutes for heavy trading days, or unset to disable:
# CHUD_THOUGHT_POST_MINUTES=30
# In OpenClaw’s own settings, pick the cheapest model that still feels OK for tool use (often Haiku / small) — that bill is separate from this .env.

# Local Ollama ($0, no cloud quota). Install from https://ollama.com then: ollama pull qwen2.5:7b  (or llama3.2, etc.)
# Leave cloud keys empty OR set CHUD_LLM_PROVIDER=ollama to force Ollama even if keys exist.
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# CHUD_LLM_PROVIDER=ollama

# Fully free option for this server (Google AI Studio key): picks, sell/hold, site chat, thought lines — no Anthropic/OpenAI needed.
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# Optional model id (default gemini-2.0-flash). Also accepts GOOGLE_AI_API_KEY / GOOGLE_GENERATIVE_AI_API_KEY.
# GEMINI_MODEL=gemini-2.0-flash

# If OpenClaw is the only brain pressing buy/sell, turn Chud’s own auto-trader off:
# CHUD_OPENCLAW_ONLY=1

# OPENAI_API_KEY=

# While holding a coin, the bot asks Claude “sell or hold?” on this interval (ms). Default 120000 = 2 min.
# CHUD_HOLD_POLL_MS=120000
# BIRDEYE_API_KEY=
# CHUD_OWN_TOKEN_MINT=   (bot never buys/sells this mint)
# X: uncomment and fill all four TWITTER_* lines (and/or CHUD_X_POST_MODE=intent).
# Buy/sell tweets use OpenClaw's buy `reason` and sell JSON `reason` when long enough (chud-prefixed).
# To tweet ONLY the periodic recap (CHUD_THOUGHT_POST_MINUTES) and NOT every buy/sell:
# CHUD_X_SKIP_TRADE_TWEETS=1
# TWITTER_DISABLED=1
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# CHUD_X_POST_MODE=intent

# Every N minutes: one lowercase “chud” recap — how the session / bag / last flips feel (for X + outbox).
# N is minutes (not seconds). 5 = every five minutes (memecoin pace). Code floors the interval at 5 minutes minimum.
# Saved to data/chud-outbox.json and GET http://127.0.0.1:4000/api/chud/outbox.
# If you also set TWITTER_* or CHUD_X_POST_MODE, that recap line goes to X from this server.
# CHUD_THOUGHT_POST_MINUTES=5
